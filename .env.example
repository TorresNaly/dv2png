# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=False
PORT=5000

# API Configuration
JOBS_DIR=./jobs
CONFIG_FILE=./config.yaml

# NAS Configuration (fill in with your lab's NAS details)
# IMPORTANT: DO NOT COMMIT ACTUAL CREDENTIALS
NAS_HOST=your_nas_server_hostname
NAS_USER=your_username
NAS_PASSWORD=your_password
NAS_SHARE=share_name

# React Frontend
REACT_APP_API_URL=http://localhost:5000/api
